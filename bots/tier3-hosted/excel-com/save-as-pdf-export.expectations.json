  "predictions": [
    {
      "id": "pdf-magic-harness",
      "kind": "round-trip",
      "description": "Both PDFs exist in the pulled-back scratch dir and start with the %PDF magic (harness reads the bytes out-of-band). No PDF text extraction exists in the platform yet, so content assertions stop at the header + nonzero size.",
      "expr": {
        "and": [
          {
            "starts_with": [
              {
                "read_value": [
                  {
                    "file": "{var:_sgtScratchDir}/all.pdf"
                  }
                ]
              },
              "%PDF"
            ]
          },
          {
            "starts_with": [
              {
                "read_value": [
                  {
                    "file": "{var:_sgtScratchDir}/sheettwo.pdf"
                  }
                ]
              },
              "%PDF"
            ]
          }
        ]
      }
    },
    {
      "id": "pdf-magic-in-bot",
      "kind": "round-trip",
      "description": "The in-bot reads agree (dual witness) and are non-trivially sized.",
      "expr": {
        "and": [
          {
            "starts_with": [
              {
                "$var": "pdfAll"
              },
              "%PDF"
            ]
          },
          {
            "starts_with": [
              {
                "$var": "pdfSheet"
              },
              "%PDF"
            ]
          },
          {
            "greater_than": [
              {
                "size_of": [
                  {
                    "$var": "pdfAll"
                  }
                ]
              },
              500
            ]
          },
          {
            "greater_than": [
              {
                "size_of": [
                  {
                    "$var": "pdfSheet"
                  }
                ]
              },
              500
            ]
          }
        ]
      }
    }
  ]
