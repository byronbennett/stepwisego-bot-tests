          "server-up"
        ]
      }
    },
    {
      "id": "binary-fidelity-hash-chain",
      "kind": "round-trip",
      "description": "base64(original) === base64(after zip → sftp up → sftp down → unzip) — the hash chain proves BINARY fidelity end to end; guard rejects the vacuous both-empty case",
      "expr": {
        "and": [
          {
            "not_equals": [
              {
                "$var": "b64orig"
              },
              "SENTINEL"
            ]
          },
          {
            "not_equals": [
              {
                "$var": "b64orig"
              },
              ""
            ]
          },
          {
            "equals": [
              {
                "$var": "b64orig"
              },
              {
                "$var": "b64back"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "crlf-unmangled",
      "kind": "round-trip",
      "description": "the CRLF corpus survives unmangled (transfer-mode trap): text read is byte-exact including \\r\\n",
      "expr": {
        "equals": [
          {
            "$var": "csvText"
          },
          "id,amount,name\r\n1,10.10,Ünïcødé\r\n2,99999999999999999999.99,漢字\r\n"
        ]
      }
    },
    {
      "id": "csv-parses-post-transfer",
      "kind": "round-trip",
      "description": "csv-to-json parses the round-tripped file into exactly 2 data rows",
      "expr": {
        "equals": [
          {
            "length": [
