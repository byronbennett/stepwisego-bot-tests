                "$var": "csvRows"
              }
            ]
          },
          2
        ]
      }
    },
    {
      "id": "remote-listing-and-cleanup",
      "kind": "round-trip",
      "description": "listing pinned exactly [bundle.zip] after upload; empty after cleanup; jail agrees",
      "expr": {
        "and": [
          {
            "equals": [
