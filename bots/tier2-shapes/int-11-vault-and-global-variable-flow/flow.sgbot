      "stepName": "act: create session table + seed row keyed by {gbl-var:sgtDbMarker}",
      "parentGuid": null,
      "actionType": "action",
      "actionOp": {
        "actionName": "db-sql-query",
        "actionPropValues": {
          "connectionVariable": {
