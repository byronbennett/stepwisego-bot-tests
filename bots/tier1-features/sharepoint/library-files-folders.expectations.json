      "description": "sp-manage-folder Create published success=true and a folder URL containing the session folder name",
      "expr": {
        "and": [
          {
            "equals": [
              {
                "$stepOut": {
                  "stepGuid": "51b70001-0000-4000-8000-000000000003",
                  "name": "success"
                }
              },
              true
            ]
          },
          {
            "contains": [
              {
                "$stepOut": {
                  "stepGuid": "51b70001-0000-4000-8000-000000000003",
                  "name": "folderUrl"
                }
              },
              "-fld"
            ]
          }
        ]
      }
    },
    {
      "id": "pred-upload-published-id",
      "kind": "round-trip",
      "description": "single upload published a non-empty driveItem id and a webUrl into the session folder",
      "expr": {
        "and": [
          {
            "not_equals": [
              {
                "$stepOut": {
                  "stepGuid": "51b70001-0000-4000-8000-000000000004",
                  "name": "itemId"
                }
              },
              ""
            ]
          },
          {
            "contains": [
              {
                "$stepOut": {
                  "stepGuid": "51b70001-0000-4000-8000-000000000004",
                  "name": "fileUrl"
                }
              },
              "/Shared%20Documents/"
            ]
          }
        ]
      }
    },
    {
      "id": "pred-overwrite-replaces-in-place",
      "kind": "round-trip",
      "description": "overwrite=true re-upload lands on the SAME driveItem id — replacement, not a duplicate",
      "expr": {
        "equals": [
          {
            "$stepOut": {
              "stepGuid": "51b70001-0000-4000-8000-000000000006",
              "name": "itemId"
            }
          },
          {
            "$stepOut": {
              "stepGuid": "51b70001-0000-4000-8000-000000000004",
              "name": "itemId"
            }
          }
        ]
      }
    },
    {
      "id": "pred-conflict-is-specific",
      "kind": "round-trip",
      "description": "overwrite=false against an existing name fails with the upload-conflict contract (Upload failed (409)), not a silent success",
      "expr": {
        "contains": [
