        "and": [
          {
            "equals": [
              {
                "$var": "binB64"
              },
              "AAECA//+U0c="
            ]
          },
          {
            "equals": [
              {
                "$var": "crumbs"
              },
              [
                "bin-b64-roundtrip-ok"
              ]
            ]
          }
        ]
      }
    },
