      "actionType": "action",
      "stepPrefix": "slv",
      "actionOp": {
        "actionName": "loop",
        "actionPropValues": {
          "loopType": { "value": "csv" },
          "csvSource": { "value": "{var:csvText}" },
          "csvHasHeaders": { "value": true },
          "csvDelimiter": { "value": "comma" },
          "csvTypingMode": { "value": "string" },
          "maxIterations": { "value": 1000 }
