    { "name": "csvText", "token": "{var:csvText}", "tokenPrefix": "var", "valueSource": "bot", "dataType": "text", "value": "id,city\n1,Oslo\n2,Lima", "defaultValue": "id,city\n1,Oslo\n2,Lima", "isPrivate": false, "isSecureText": false, "saveValue": false, "isStep": false },
    { "name": "crumbsRows", "token": "{var:crumbsRows}", "tokenPrefix": "var", "valueSource": "bot", "dataType": "listOfTexts", "value": [], "defaultValue": [], "isPrivate": false, "isSecureText": false, "saveValue": false, "isStep": false },
