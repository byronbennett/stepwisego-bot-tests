  "files": [],
  "steps": [
    {
      "stepGuid": "e1a00008-0000-0000-0000-000000000001",
      "stepName": "Parse JSON rows",
      "parentGuid": null,
      "actionType": "action",
      "actionOp": {
        "actionName": "json-parse",
        "actionPropValues": {
          "jsonString": { "value": "[{\"name\":\"Alice\",\"amt\":\"10.50\"},{\"name\":\"Bob\",\"amt\":\"3.25\"}]" },
          "resultVariable": { "value": "{var:jsonRows}" }
        },
        "requiresChildSteps": false
      },
      "children": [], "seq": 1, "status": "enabled", "isBreakpoint": false, "ignoreErrors": false, "comments": "", "backgroundColor": null
