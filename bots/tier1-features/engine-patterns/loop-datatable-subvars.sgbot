    {
      "stepGuid": "e1a00008-0000-0000-0000-000000000002",
      "stepName": "JSON → DataTable",
      "parentGuid": null,
      "actionType": "action",
      "actionOp": {
        "actionName": "json-to-datatable",
        "actionPropValues": {
          "jsonVariable": { "value": "{var:jsonRows}" },
          "columnMode": { "value": "union" },
          "dataTableVariable": { "value": "{var:dt}" }
        },
        "requiresChildSteps": false
      },
      "children": [], "seq": 2, "status": "enabled", "isBreakpoint": false, "ignoreErrors": false, "comments": "", "backgroundColor": null
    },
    {
      "stepGuid": "e1a00008-0000-0000-0000-000000000003",
      "stepName": "Rows in DataTable: {var:dt}",
      "parentGuid": null,
      "actionType": "action",
      "stepPrefix": "sld",
      "actionOp": {
        "actionName": "loop",
        "actionPropValues": {
          "loopType": { "value": "dataTable" },
          "dataTableVariable": { "value": "{var:dt}" },
          "maxIterations": { "value": 1000 }
        },
        "requiresChildSteps": true
      },
      "children": [
        {
          "stepGuid": "e1a00008-0000-0000-0000-000000000301",
          "stepName": "record row crumb via column sub-variables",
          "parentGuid": "e1a00008-0000-0000-0000-000000000003",
          "actionType": "action",
          "actionOp": {
            "actionName": "add-to-list",
            "actionPropValues": {
              "listVariable": { "value": "{var:crumbsRows}" },
              "value": { "value": "{sld:loopCount}:{sld-currentDataRow:name}={sld-currentDataRow:amt}" },
              "addPosition": { "value": "end" }
            },
            "requiresChildSteps": false
          },
          "children": [], "seq": 4, "status": "enabled", "isBreakpoint": false, "ignoreErrors": false, "comments": "", "backgroundColor": null
