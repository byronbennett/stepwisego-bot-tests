    {
      "stepGuid": "a6d10004-0000-0000-0000-000000000005",
      "stepName": "arrange: drop stale proc, then create proc returning rows with n >= @minN",
      "parentGuid": null,
      "actionType": "action",
      "actionOp": {
        "actionName": "db-sql-modify-odbc",
        "actionPropValues": {
          "connectionType": {
            "value": "ODBC"
          },
          "connectionString": {
            "value": "{svar:sgtOdbcMssql}"
          },
          "sql": {
            "value": "DROP PROCEDURE IF EXISTS sgtester.sgt_t6_odbc_top"
          }
        },
        "requiresChildSteps": false
      },
      "children": [],
      "seq": 6,
      "status": "enabled",
