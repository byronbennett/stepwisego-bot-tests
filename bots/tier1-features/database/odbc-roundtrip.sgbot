    },
    {
      "stepGuid": "a6d10004-0000-0000-0000-000000000006",
      "stepName": "arrange: create stored procedure",
      "parentGuid": null,
      "actionType": "action",
      "actionOp": {
        "actionName": "db-sql-modify-odbc",
        "actionPropValues": {
          "connectionType": {
            "value": "ODBC"
          },
          "connectionString": {
            "value": "{svar:sgtOdbcMssql}"
          },
          "sql": {
            "value": "CREATE PROCEDURE sgtester.sgt_t6_odbc_top @minN INT AS BEGIN SET NOCOUNT ON; SELECT id, name FROM sgtester.sgt_t6_odbc WHERE n >= @minN ORDER BY id; END"
          }
        },
        "requiresChildSteps": false
      },
      "children": [],
      "seq": 7,
