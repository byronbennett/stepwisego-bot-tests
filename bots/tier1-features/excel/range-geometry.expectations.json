      "kind": "round-trip",
      "description": "used-range is the bounding box of ALL data (both islands + header): A1:F7 — NOT the contiguous region of any single island.",
      "expr": {
        "equals": [
          {
            "$var": "usedRange"
          },
          "A1:F7"
        ]
