                "$var": "cdValues"
              },
              [
                "10",
                "20",
                "30"
              ]
            ]
          },
          {
            "equals": [
              {
                "$var": "cdFormula"
              },
              "=B4*10"
            ]
          }
        ]
      }
    },
    {
