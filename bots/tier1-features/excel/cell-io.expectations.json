    {
      "id": "row-and-column-readers",
      "kind": "round-trip",
      "description": "get-values-for-row 1 sees the whole first row; get-values-for-column A respects includeHeaders (false starts at row 2; default true reads from row 1). Three different readers agree on the same grid.",
      "expr": {
        "and": [
          {
            "equals": [
              {
                "$var": "rowVals"
              },
              [
                "r1",
                "c1",
                "c2",
                "c3"
              ]
            ]
          },
          {
            "equals": [
              {
                "$var": "colNoHdr"
              },
              [
                "r2",
                "r3"
              ]
            ]
          },
          {
            "equals": [
              {
                "$var": "colWithHdr"
              },
              [
                "r1",
                "r2",
                "r3"
              ]
            ]
          }
        ]
      }
    },
    {
      "id": "clear-values-ranged-then-whole-sheet",
      "kind": "round-trip",
      "description": "Ranged clear A2:A3 nulls exactly those cells (A1 survives; cleared cells read '' under skipEmpty=false — unlike the empty-string write, these are true nulls); the no-range clear then empties the ENTIRE sheet ([] against a SENTINEL default proves the final read really ran).",
      "expr": {
