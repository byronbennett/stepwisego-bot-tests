      "description": "add-sheet default appends at the end, position=start prepends (orderNo takes effect through the serialize/deserialize round-trip every mutation performs): [Zulu, Sheet1, Alpha].",
      "expr": {
        "equals": [
          {
            "$var": "namesAfterAdds"
          },
          [
            "Zulu",
            "Sheet1",
            "Alpha"
          ]
        ]
      }
    },
    {
      "id": "name-at-index-one-based",
      "kind": "round-trip",
      "description": "sheet-name-at-index is 1-based and agrees element-wise with get-sheet-names (two readers over the same order); index 9 errors out-of-range (buried, sentinel untouched).",
      "expr": {
        "and": [
          {
            "equals": [
              {
                "$var": "idx1"
              },
              "Zulu"
            ]
          },
          {
            "equals": [
              {
                "$var": "idx3"
              },
              "Alpha"
            ]
          },
          {
            "equals": [
              {
                "$var": "idxBad"
              },
              "UNTOUCHED"
            ]
          }
        ]
      }
    },
    {
      "id": "rename-keeps-content",
      "kind": "round-trip",
      "description": "rename-sheet Sheet1→Core preserves cell content: Core!A1 still reads the marker written before the rename.",
      "expr": {
        "equals": [
          {
            "$var": "coreA1"
          },
          "s1"
        ]
      }
    },
    {
      "id": "copy-is-deep",
      "kind": "round-trip",
      "description": "copy-sheet duplicates cells (CoreCopy!A1 = s1) AND the copy is independent: mutating CoreCopy!A1 leaves Core!A1 untouched.",
      "expr": {
        "and": [
          {
            "equals": [
              {
                "$var": "copyA1"
              },
              "s1"
            ]
          },
          {
            "equals": [
              {
                "$var": "coreA1After"
              },
              "s1"
            ]
          }
        ]
      }
    },
    {
      "id": "move-reorders-and-redirects-default",
      "kind": "round-trip",
      "description": "move-sheet CoreCopy→position 1 reorders to [CoreCopy, Zulu, Core, Alpha] AND a default-sheet read (no sheetName) now hits the moved sheet — worksheets[0] is what 'default sheet' means in Fast mode.",
      "expr": {
        "and": [
          {
            "equals": [
              {
                "$var": "namesAfterMove"
              },
              [
                "CoreCopy",
                "Zulu",
                "Core",
                "Alpha"
              ]
            ]
          },
          {
            "equals": [
              {
                "$var": "defaultA1"
              },
              "changed"
            ]
          }
        ]
      }
    },
    {
      "id": "activate-does-not-redirect-fast-reads",
      "kind": "round-trip",
      "description": "Pinned quirk: xl-activate-sheet records the active tab in workbook views (visible when the file opens in Excel), but Fast-mode default reads still follow sheet POSITION — after activating Zulu the default read is still CoreCopy's value.",
      "expr": {
        "equals": [
          {
            "$var": "stillDefaultA1"
          },
          "changed"
        ]
      }
    },
