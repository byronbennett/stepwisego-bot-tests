      "description": "all three result variables kept their SENTINEL — failed connections never store partial results",
      "expr": {
        "and": [
          {
            "equals": [
              {
                "$var": "wpRes"
              },
              "SENTINEL"
            ]
          },
          {
            "equals": [
              {
                "$var": "crNames"
              },
              "SENTINEL"
            ]
          },
          {
            "equals": [
              {
                "$var": "missNames"
              },
              "SENTINEL"
            ]
          }
        ]
      }
    },
    {
      "id": "run-continued",
      "kind": "round-trip",
      "description": "crumb variable + crumb file prove the run continued past the buried failures",
      "expr": {
        "and": [
          {
            "equals": [
              {
                "$var": "crumb"
              },
              "continued-after-failures"
            ]
          },
          {
            "equals": [
              {
                "read_value": [
