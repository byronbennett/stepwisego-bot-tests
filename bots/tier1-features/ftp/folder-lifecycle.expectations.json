  "predictions": [
    {
      "id": "server-launched",
      "kind": "round-trip",
      "description": "detached sftp listener up before the bot proceeded",
      "expr": {
        "equals": [
          {
            "$var": "launchOut"
          },
          "server-up"
        ]
      }
    },
    {
      "id": "folder-listing-sorted",
      "kind": "round-trip",
      "description": "get-folder-names sees exactly a,b (sorted compare)",
      "expr": {
        "equals": [
          {
            "$var": "workSorted"
          },
          "a,b"
        ]
      }
    },
    {
      "id": "folder-filter-wildcard",
      "kind": "round-trip",
      "description": "wildcard filter a* returns exactly [a]",
      "expr": {
        "equals": [
          {
            "$var": "aOnly"
          },
          [
            "a"
          ]
        ]
      }
    },
    {
      "id": "nonempty-delete-pinned",
      "kind": "round-trip",
      "description": "delete-folder on a NON-EMPTY folder succeeds (client-side recursive rmdir) and the folder is gone in-bot",
      "expr": {
        "equals": [
          {
            "$var": "bGone"
          },
          false
        ]
      }
    },
    {
      "id": "backing-shape",
      "kind": "external-write",
      "description": "jail agrees: /work/a/inner exists, /work/b is physically gone",
      "expr": {
        "and": [
          {
            "file_exists": [
              {
                "file": "{var:_sgtScratchDir}/sftp-root/work/a/inner"
              }
            ]
          },
          {
            "not": [
              {
                "file_exists": [
                  {
                    "file": "{var:_sgtScratchDir}/sftp-root/work/b"
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
